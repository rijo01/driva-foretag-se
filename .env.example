# Kopiera till .env.local och fyll i riktiga värden. .env.local committas aldrig.

# --- Stripe (betalda startguider) ---
# Hämta i Stripe Dashboard → Developers → API keys. Använd TEST-nyckeln vid utveckling.
STRIPE_SECRET_KEY=sk_test_din_hemliga_nyckel_har

# Basadress för success_url/cancel_url i Stripe Checkout.
# Lokalt: http://localhost:3000 · Produktion: https://driva-foretag.se
# Om den utelämnas används request-origin, annars https://driva-foretag.se.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Resend (befintligt lead-formulär) ---
RESEND_API_KEY=re_din_nyckel_har
LEAD_EMAIL=info@driva-foretag.se
