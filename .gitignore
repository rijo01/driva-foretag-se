# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# guide-PDF:er (betalvara, serveras via /api/download – aldrig statiskt)
# Endast färdiga, granskade guider committas. byggforetag är klar; övriga
# läggs till när deras innehåll är skrivet och faktagranskat.
content/guides-pdf/*.pdf
!content/guides-pdf/byggforetag.pdf
!content/guides-pdf/akeri.pdf
!content/guides-pdf/restaurang.pdf
!content/guides-pdf/stadforetag.pdf
